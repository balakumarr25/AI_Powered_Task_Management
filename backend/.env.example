SPRING_PROFILES_ACTIVE=mysql
SERVER_PORT=8080
JWT_SECRET=change-this-secret-key-to-at-least-32-characters-long-for-production
JWT_EXPIRATION_MS=86400000
CORS_ORIGINS=http://localhost:5173

# MySQL Database
DATABASE_URL=jdbc:mysql://localhost:3306/taskportal?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
